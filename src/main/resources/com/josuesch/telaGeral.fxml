<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.text.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.shape.*?>
<?import javafx.scene.image.*?>
<?import java.lang.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.josuesch.PrimaryController">
   <children>
      <HBox>
         <children>
            <VBox prefHeight="500.0" prefWidth="500.0">
               <children>
                  <TabPane prefHeight="300.0" side="LEFT" tabClosingPolicy="UNAVAILABLE">
                    <tabs>
                      <Tab closable="false" text="Lanches">
                        <content>
                          <AnchorPane minHeight="0.0" minWidth="0.0">
                                 <children>
                                    <VBox layoutX="24.0" layoutY="14.0">
                                       <children>
                                          <HBox>
                                             <children>
                                                <VBox alignment="TOP_CENTER">
                                                   <children>
                                                      <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                                                         <image>
                                                            <Image url="@burger-duplo.png" />
                                                         </image>
                                                      </ImageView>
                                                      <HBox alignment="TOP_CENTER">
                                                         <children>
                                                            <Button fx:id="btSubLanche1" mnemonicParsing="false" onAction="#onActionBtSubLanche1" text="-" />
                                                            <TextField fx:id="txQtdLanche1" alignment="CENTER" editable="false" prefWidth="40.0" />
                                                            <Button fx:id="btAddLanche1" mnemonicParsing="false" onAction="#onActionBtAddLanche1" text="+" />
                                                         </children>
                                                      </HBox>
                                                   </children>
                                                </VBox>
                                                <VBox alignment="TOP_CENTER">
                                                   <children>
                                                      <ImageView fitHeight="150.0" fitWidth="200.0" pickOnBounds="true" preserveRatio="true">
                                                         <image>
                                                            <Image url="@burger-duplo.png" />
                                                         </image>
                                                      </ImageView>
                                                      <HBox alignment="TOP_CENTER">
                                                         <children>
                                                            <Button fx:id="btSubLanche2" mnemonicParsing="false" text="-" />
                                                            <TextField fx:id="txQtdLanche2" alignment="CENTER" editable="false" prefWidth="40.0" />
                                                            <Button fx:id="btAddLanche2" mnemonicParsing="false" text="+" />
                                                         </children>
                                                      </HBox>
                                                   </children>
                                                </VBox>
                                             </children>
                                          </HBox>
                                       </children>
                                    </VBox>
                                 </children>
                              </AnchorPane>
                        </content>
                      </Tab>
                      <Tab closable="false" text="Bebidas">
                        <content>
                          <AnchorPane minHeight="0.0" minWidth="0.0" />
                        </content>
                      </Tab>
                        <Tab closable="false" text="Sobremesas">
                          <content>
                            <AnchorPane minHeight="0.0" minWidth="0.0" />
                          </content>
                        </Tab>
                    </tabs>
                  </TabPane>
                  <HBox alignment="CENTER_RIGHT" prefHeight="200.0">
                     <children>
                        <VBox alignment="CENTER" prefWidth="400.0">
                           <children>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Total: ">
                                       <font>
                                          <Font size="31.0" />
                                       </font>
                                    </Text>
                                    <TextField fx:id="txTotalPedido" alignment="CENTER" editable="false" prefWidth="300.0">
                                       <font>
                                          <Font size="25.0" />
                                       </font>
                                    </TextField>
                                 </children>
                              </HBox>
                              <HBox alignment="CENTER">
                                 <children>
                                    <Button fx:id="btConfirmarPedido" mnemonicParsing="false" text="Confirmar" />
                                    <Button fx:id="btCancelarPedido" mnemonicParsing="false" text="Cancelar" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </HBox>
               </children>
            </VBox>
            <VBox minHeight="-Infinity" minWidth="-Infinity" prefHeight="10.0" prefWidth="10.0" />
            <Line startY="500.0" />
            <VBox minHeight="-Infinity" minWidth="-Infinity" prefHeight="10.0" prefWidth="10.0" />
            <VBox prefHeight="500.0" prefWidth="500.0">
               <children>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Lista de Pedidos:" />
                  <TextArea fx:id="txListaDePedidos" editable="false" prefHeight="200.0" prefWidth="200.0" />
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Processar Pedido" />
                  <HBox>
                     <children>
                        <Text strokeType="OUTSIDE" strokeWidth="0.0" text="N°:">
                           <font>
                              <Font size="23.0" />
                           </font>
                        </Text>
                        <TextField fx:id="txNumeroPedido" />
                        <Button fx:id="btPedidoAnterior" mnemonicParsing="false" text="Anterior" />
                        <Button fx:id="btProximoPedido" mnemonicParsing="false" text="Proximo" />
                     </children>
                  </HBox>
                  <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Dados:" />
                  <TextArea fx:id="txDadosPedidoSelecionado" editable="false" prefHeight="100.0" prefWidth="200.0" />
                  <HBox alignment="CENTER">
                     <children>
                        <Button fx:id="BtIniciarPreparo" mnemonicParsing="false" text="Iniciar Preparo" />
                        <Button fx:id="btConcluir" mnemonicParsing="false" text="Concluir" />
                        <Button fx:id="btCancelar" mnemonicParsing="false" text="Cancelar" />
                     </children>
                  </HBox>
               </children></VBox>
         </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
